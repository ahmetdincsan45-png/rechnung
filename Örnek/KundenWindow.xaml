<Window x:Class="Örnek.KundenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Kunden" Height="600" Width="900" MinHeight="500" MinWidth="700" WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <WrapPanel Grid.Row="0" Margin="0,0,0,10">
            <Button x:Name="NewButton" MinWidth="110" MaxWidth="180" Margin="0,0,10,10" Click="Yeni_Click" Content="Neu"/>
            <Button x:Name="DeleteButton" MinWidth="110" MaxWidth="180" Margin="0,0,10,10" Click="Sil_Click" Content="Löschen"/>
            <Button x:Name="SaveButton" MinWidth="110" MaxWidth="180" Margin="0,0,10,10" Click="Kaydet_Click" Content="Speichern"/>
        </WrapPanel>

        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
        <Grid MinWidth="760">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.8*"/>
                <ColumnDefinition Width="1.2*"/>
            </Grid.ColumnDefinitions>

            <DataGrid x:Name="KundenGrid" Grid.Column="0" AutoGenerateColumns="False" IsReadOnly="True"
                      SelectionChanged="KundenGrid_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn x:Name="CompanyColumn" Header="Firma" Binding="{Binding Adresse.Firmenname}" Width="*"/>
                    <DataGridTextColumn x:Name="CityColumn" Header="Stadt" Binding="{Binding Adresse.Stadt}" Width="150"/>
                    <DataGridTextColumn x:Name="EmailColumn" Header="E-Mail" Binding="{Binding Adresse.Email}" Width="220"/>
                </DataGrid.Columns>
            </DataGrid>

            <GroupBox x:Name="DetailGroupBox" Grid.Column="1" Header="Details" Margin="18,0,0,0" MinWidth="260">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="CompanyLabel" Grid.Row="0" Grid.Column="0" Margin="0,0,10,8" VerticalAlignment="Center" TextWrapping="Wrap" Text="Firma:"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" Text="{Binding Selected.Adresse.Firmenname, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock x:Name="StreetLabel" Grid.Row="1" Grid.Column="0" Margin="0,0,10,8" VerticalAlignment="Center" TextWrapping="Wrap" Text="Straße:"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" Text="{Binding Selected.Adresse.Strasse, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock x:Name="NumberLabel" Grid.Row="2" Grid.Column="0" Margin="0,0,10,8" VerticalAlignment="Center" TextWrapping="Wrap" Text="Hausnr.:"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Margin="0,0,0,8" Text="{Binding Selected.Adresse.Hausnummer, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock x:Name="PostalCodeLabel" Grid.Row="3" Grid.Column="0" Margin="0,0,10,8" VerticalAlignment="Center" TextWrapping="Wrap" Text="PLZ:"/>
                        <TextBox Grid.Row="3" Grid.Column="1" Margin="0,0,0,8" Text="{Binding Selected.Adresse.Postleitzahl, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock x:Name="CityLabel" Grid.Row="4" Grid.Column="0" Margin="0,0,10,8" VerticalAlignment="Center" TextWrapping="Wrap" Text="Stadt:"/>
                        <TextBox Grid.Row="4" Grid.Column="1" Margin="0,0,0,8" Text="{Binding Selected.Adresse.Stadt, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock x:Name="CountryLabel" Grid.Row="5" Grid.Column="0" Margin="0,0,10,8" VerticalAlignment="Center" TextWrapping="Wrap" Text="Land:"/>
                        <TextBox Grid.Row="5" Grid.Column="1" Margin="0,0,0,8" Text="{Binding Selected.Adresse.Land, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock x:Name="EmailLabel" Grid.Row="6" Grid.Column="0" Margin="0,0,10,0" VerticalAlignment="Center" TextWrapping="Wrap" Text="E-Mail:"/>
                        <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding Selected.Adresse.Email, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                </ScrollViewer>
            </GroupBox>
        </Grid>
        </ScrollViewer>

        <WrapPanel Grid.Row="2" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="CloseButton" MinWidth="110" MaxWidth="180" Margin="0,0,10,0" Click="Kapat_Click" Content="Schließen"/>
        </WrapPanel>
    </Grid>
</Window>
