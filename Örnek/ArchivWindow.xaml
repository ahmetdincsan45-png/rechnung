<Window x:Class="Örnek.ArchivWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
         Title="Archiv" Height="600" Width="900" MinWidth="760" MinHeight="420" WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <WrapPanel Grid.Row="0" Margin="0,0,0,10" ItemHeight="34">
            <Button x:Name="RefreshButton" MinWidth="110" MaxWidth="180" Margin="0,0,10,10" Click="Yenile_Click" Content="Aktualisieren"/>
            <Button x:Name="OpenPdfButton" MinWidth="140" MaxWidth="200" Margin="0,0,10,10" Click="PdfAc_Click" Content="PDF öffnen"/>
            <Button x:Name="OpenFolderButton" MinWidth="140" MaxWidth="200" Margin="0,0,10,10" Click="KlasorAc_Click" Content="Ordner öffnen"/>
            <Button x:Name="DeleteButton" MinWidth="120" MaxWidth="180" Margin="0,0,10,10" Click="Sil_Click" Content="Löschen"/>
            <Button x:Name="EditButton" MinWidth="140" MaxWidth="180" Margin="0,0,0,10" Click="Duzenle_Click" Content="Bearbeiten"/>
        </WrapPanel>

        <WrapPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBox x:Name="SearchTextBox" Margin="0,0,10,10" MinWidth="160" Width="180" VerticalContentAlignment="Center" TextChanged="SearchFilter_Changed"/>
            <ComboBox x:Name="TypeFilterComboBox" Margin="0,0,10,10" MinWidth="140" Width="160" SelectionChanged="SearchFilter_Changed"/>
            <ComboBox x:Name="StatusFilterComboBox" Margin="0,0,10,10" MinWidth="140" Width="160" SelectionChanged="SearchFilter_Changed"/>
            <DatePicker x:Name="FromDatePicker" Margin="0,0,10,10" MinWidth="130" SelectedDateChanged="SearchFilter_Changed"/>
            <DatePicker x:Name="ToDatePicker" Margin="0,0,0,10" MinWidth="130" SelectedDateChanged="SearchFilter_Changed"/>
        </WrapPanel>

        <DataGrid Grid.Row="2"
                  x:Name="ArchivGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  PreviewMouseLeftButtonUp="ArchivGrid_PreviewMouseLeftButtonUp">
            <DataGrid.Columns>
                <DataGridTextColumn x:Name="TypeColumn" Header="Typ" Binding="{Binding DokumentTyp}" Width="120"/>
                <DataGridTextColumn x:Name="NumberColumn" Header="Nr." Binding="{Binding DokumentNummer}" Width="150"/>
                <DataGridTextColumn x:Name="AttachmentCountColumn" Header="Belege" Binding="{Binding AngehaengteBelegAnzahl}" Width="80"/>
                <DataGridTextColumn x:Name="StatusColumn" Header="Status" Binding="{Binding Status}" Width="130"/>
                <DataGridTextColumn x:Name="DateColumn" Header="Datum" Binding="{Binding Datum}" Width="150"/>
                <DataGridTextColumn x:Name="LastActionColumn" Header="Letzte Aktion" Binding="{Binding LetzteAktionText}" Width="220"/>
                <DataGridTextColumn x:Name="CustomerColumn" Header="Kunde" Binding="{Binding Kunde}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
