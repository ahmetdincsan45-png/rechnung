<Window x:Class="Örnek.AngebotMetinleriWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Angebotstexte" Height="700" Width="800" MinHeight="520" MinWidth="520" WindowStartupLocation="CenterOwner">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock x:Name="HeaderText" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" TextWrapping="Wrap" Text="Angebot PDF - Texte (2. Seite)" />

                <TextBlock x:Name="IntroLabel" FontWeight="SemiBold" TextWrapping="Wrap" Text="Einleitung (optional)" />
                <TextBox Margin="0,6,0,12" Height="90" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Text="{Binding AngebotEinleitungText, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock x:Name="LiabilityLabel" FontWeight="SemiBold" TextWrapping="Wrap" Text="Haftungsbegrenzung (optional)" />
                <TextBox Margin="0,6,0,12" Height="140" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Text="{Binding AngebotHaftungText, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock x:Name="OrderConfirmationLabel" FontWeight="SemiBold" TextWrapping="Wrap" Text="Auftragsbestätigungstext (optional)" />
                <TextBox Margin="0,6,0,12" Height="140" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Text="{Binding AngebotAuftragText, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock x:Name="CancellationLabel" FontWeight="SemiBold" TextWrapping="Wrap" Text="Widerrufsbelehrung (optional)" />
                <TextBlock x:Name="InfoText" Margin="0,4,0,6" Foreground="#666666" FontSize="12"
                           TextWrapping="Wrap"
                           Text="Hinweis: In der Regel nur für B2C (Verbraucher) erforderlich. Wenn leer, erscheint der Abschnitt nicht im PDF." />
                <TextBox Margin="0,0,0,12" Height="140" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Text="{Binding AngebotWiderrufText, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
        </ScrollViewer>

        <WrapPanel Grid.Row="1" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="CancelButton" MinWidth="110" MaxWidth="180" Margin="0,0,10,10" Click="Cancel_Click" Content="Abbrechen"/>
            <Button x:Name="SaveButton" MinWidth="110" MaxWidth="180" Margin="0,0,0,10" Click="Save_Click" Content="Speichern"/>
        </WrapPanel>
    </Grid>
</Window>
