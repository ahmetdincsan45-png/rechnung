<Window x:Class="Örnek.ArtikelAuswahlWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Aus Katalog hinzufügen" Height="550" Width="900" MinHeight="440" MinWidth="640" WindowStartupLocation="CenterOwner">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="SearchLabel" Grid.Column="0" Margin="0,0,10,0" VerticalAlignment="Center" TextWrapping="Wrap" Text="Suche:"/>
            <TextBox Grid.Column="1" x:Name="SearchBox" TextChanged="SearchBox_TextChanged"/>
        </Grid>

        <DataGrid Grid.Row="1" x:Name="ArtikelGrid" AutoGenerateColumns="False" IsReadOnly="True"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  MouseDoubleClick="ArtikelGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn x:Name="ArtikelNrColumn" Header="Nr." Binding="{Binding ArtikelNr}" Width="120"/>
                <DataGridTextColumn x:Name="ArtikelNameColumn" Header="Bezeichnung" Binding="{Binding Bezeichnung}" Width="*"/>
                <DataGridTextColumn x:Name="ArtikelUnitColumn" Header="Einheit" Binding="{Binding Einheit}" Width="90"/>
                <DataGridTextColumn x:Name="ArtikelPriceColumn" Header="Preis" Binding="{Binding StandardPreis, StringFormat=N2}" Width="110"/>
                <DataGridTextColumn x:Name="ArtikelTaxColumn" Header="MwSt.%" Binding="{Binding StandardMwSt, StringFormat=0.##}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <WrapPanel Grid.Row="2" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="AddButton" MinWidth="110" MaxWidth="180" Margin="0,0,10,10" Click="Ok_Click" Content="Hinzufügen"/>
            <Button x:Name="CancelButton" MinWidth="110" MaxWidth="180" Margin="0,0,0,10" Click="Cancel_Click" Content="Abbrechen"/>
        </WrapPanel>
    </Grid>
</Window>
