<Window x:Class="Örnek.FirmaBilgileriWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Firmendaten" Height="650" Width="600" MinHeight="540" MinWidth="480" WindowStartupLocation="CenterOwner">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="HeaderText" Grid.Row="0" Text="Firmendaten" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" TextWrapping="Wrap"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid MinWidth="430">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="CompanyNameLabel" Grid.Row="0" Grid.Column="0" Margin="0,0,10,8" VerticalAlignment="Center" TextWrapping="Wrap" Text="Firmenname:"/>
                <TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" Text="{Binding Profil.Adresse.Firmenname, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock x:Name="StreetLabel" Grid.Row="1" Grid.Column="0" Margin="0,0,10,8" VerticalAlignment="Center" TextWrapping="Wrap" Text="Straße:"/>
                <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" Text="{Binding Profil.Adresse.Strasse, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock x:Name="NumberLabel" Grid.Row="2" Grid.Column="0" Margin="0,0,10,8" VerticalAlignment="Center" TextWrapping="Wrap" Text="Hausnr.:"/>
                <TextBox Grid.Row="2" Grid.Column="1" Margin="0,0,0,8" Text="{Binding Profil.Adresse.Hausnummer, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock x:Name="PostalCodeLabel" Grid.Row="3" Grid.Column="0" Margin="0,0,10,8" VerticalAlignment="Center" TextWrapping="Wrap" Text="PLZ:"/>
                <TextBox Grid.Row="3" Grid.Column="1" Margin="0,0,0,8" Text="{Binding Profil.Adresse.Postleitzahl, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock x:Name="CityLabel" Grid.Row="4" Grid.Column="0" Margin="0,0,10,8" VerticalAlignment="Center" TextWrapping="Wrap" Text="Stadt:"/>
                <TextBox Grid.Row="4" Grid.Column="1" Margin="0,0,0,8" Text="{Binding Profil.Adresse.Stadt, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock x:Name="CountryLabel" Grid.Row="5" Grid.Column="0" Margin="0,0,10,8" VerticalAlignment="Center" TextWrapping="Wrap" Text="Land:"/>
                <TextBox Grid.Row="5" Grid.Column="1" Margin="0,0,0,8" Text="{Binding Profil.Adresse.Land, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock x:Name="PhoneLabel" Grid.Row="6" Grid.Column="0" Margin="0,0,10,8" VerticalAlignment="Center" TextWrapping="Wrap" Text="Telefon:"/>
                <TextBox Grid.Row="6" Grid.Column="1" Margin="0,0,0,8" Text="{Binding Profil.Adresse.Telefon, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock x:Name="EmailLabel" Grid.Row="7" Grid.Column="0" Margin="0,0,10,8" VerticalAlignment="Center" TextWrapping="Wrap" Text="E-Mail:"/>
                <TextBox Grid.Row="7" Grid.Column="1" Margin="0,0,0,8" Text="{Binding Profil.Adresse.Email, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock x:Name="WebLabel" Grid.Row="8" Grid.Column="0" Margin="0,0,10,8" VerticalAlignment="Center" TextWrapping="Wrap" Text="Web:"/>
                <TextBox Grid.Row="8" Grid.Column="1" Margin="0,0,0,8" Text="{Binding Profil.Adresse.Webseite, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock x:Name="TaxNumberLabel" Grid.Row="9" Grid.Column="0" Margin="0,0,10,8" VerticalAlignment="Center" TextWrapping="Wrap" Text="Steuernummer:"/>
                <TextBox Grid.Row="9" Grid.Column="1" Margin="0,0,0,8" Text="{Binding Profil.Steuernummer, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock x:Name="VatIdLabel" Grid.Row="10" Grid.Column="0" Margin="0,0,10,8" VerticalAlignment="Center" TextWrapping="Wrap" Text="USt-IdNr:"/>
                <TextBox Grid.Row="10" Grid.Column="1" Margin="0,0,0,8" Text="{Binding Profil.UstIdNr, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock x:Name="LogoLabel" Grid.Row="11" Grid.Column="0" Margin="0,0,10,8" VerticalAlignment="Center" TextWrapping="Wrap" Text="Logo:"/>
                <WrapPanel Grid.Row="11" Grid.Column="1" Margin="0,0,0,8">
                    <TextBox MinWidth="180" MaxWidth="320" Width="320" Margin="0,0,10,8" IsReadOnly="True" Text="{Binding Profil.LogoPath}"/>
                    <Button x:Name="SelectLogoButton" MinWidth="120" MaxWidth="180" Margin="0,0,0,8" Click="LogoSec_Click" Content="Logo auswählen"/>
                </WrapPanel>

                <TextBlock x:Name="PaymentTermsLabel" Grid.Row="12" Grid.Column="0" Margin="0,0,10,8" VerticalAlignment="Center" TextWrapping="Wrap" Text="Zahlungsbedingungen:"/>
                <TextBox Grid.Row="12" Grid.Column="1" Margin="0,0,0,8" Text="{Binding Profil.Zahlungsbedingungen, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="13" Grid.Column="0" Margin="0,0,10,8" VerticalAlignment="Center" TextWrapping="Wrap" Text="Kontoinhaber:"/>
                <TextBox Grid.Row="13" Grid.Column="1" Margin="0,0,0,8" Text="{Binding Profil.Kontoinhaber, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="14" Grid.Column="0" Margin="0,0,10,8" VerticalAlignment="Center" TextWrapping="Wrap" Text="IBAN:"/>
                <TextBox Grid.Row="14" Grid.Column="1" Margin="0,0,0,8" Text="{Binding Profil.IBAN, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="15" Grid.Column="0" Margin="0,0,10,8" VerticalAlignment="Center" TextWrapping="Wrap" Text="BIC:"/>
                <TextBox Grid.Row="15" Grid.Column="1" Margin="0,0,0,8" Text="{Binding Profil.BIC, UpdateSourceTrigger=PropertyChanged}"/>

                <Image Grid.Row="16" Grid.Column="1" Height="120" Stretch="Uniform" HorizontalAlignment="Left" Source="{Binding LogoPreview}"/>
            </Grid>
        </ScrollViewer>

        <WrapPanel Grid.Row="2" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="CancelButton" MinWidth="110" MaxWidth="180" Margin="0,0,10,10" Click="Cancel_Click" Content="Abbrechen"/>
            <Button x:Name="SaveButton" MinWidth="110" MaxWidth="180" Margin="0,0,0,10" Click="Save_Click" Content="Speichern"/>
        </WrapPanel>
    </Grid>
</Window>
