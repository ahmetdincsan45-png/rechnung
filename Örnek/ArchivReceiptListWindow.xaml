<Window x:Class="Örnek.ArchivReceiptListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Zugeordnete Belege"
        Height="430"
        Width="760"
        MinHeight="300"
        MinWidth="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource AppBackgroundBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Padding="16"
                Margin="0,0,0,12"
                Background="{StaticResource AppCardBrush}"
                BorderBrush="{StaticResource AppBorderBrush}"
                BorderThickness="1"
                CornerRadius="14">
            <StackPanel>
                <TextBlock x:Name="HeaderText"
                           Text="Zugeordnete Belege"
                           FontSize="20"
                           FontWeight="SemiBold"
                            TextWrapping="Wrap"
                           Foreground="{StaticResource AppTextPrimaryBrush}"/>
                <TextBlock x:Name="SubtitleText"
                           Margin="0,6,0,0"
                           Text="Diese Belege sind mit der ausgewählten Rechnung verknüpft."
                           TextWrapping="Wrap"
                           Foreground="{StaticResource AppTextSecondaryBrush}"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Background="{StaticResource AppCardBrush}"
                BorderBrush="{StaticResource AppBorderBrush}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="10">
            <Grid>
                <TextBlock x:Name="EmptyStateText"
                           Text="Für diese Rechnung sind aktuell keine Belege verknüpft."
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource AppTextSecondaryBrush}"
                           FontSize="14"
                           Visibility="Collapsed"/>
                <DataGrid x:Name="ReceiptsGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                           ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          MouseDoubleClick="ReceiptsGrid_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn x:Name="SupplierColumn" Header="Lieferant" Binding="{Binding Lieferant}" Width="*"/>
                        <DataGridTextColumn x:Name="NumberColumn" Header="Rechnungsnr." Binding="{Binding Rechnungsnummer}" Width="150"/>
                        <DataGridTextColumn x:Name="DateColumn" Header="Datum" Binding="{Binding Rechnungsdatum, StringFormat=dd.MM.yyyy}" Width="120"/>
                        <DataGridTextColumn x:Name="GrossColumn" Header="Brutto" Binding="{Binding Brutto, StringFormat=N2}" Width="110"/>
                        <DataGridTextColumn x:Name="ProjectColumn" Header="Projekt" Binding="{Binding Projekt}" Width="150"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <WrapPanel Grid.Row="2"
                   HorizontalAlignment="Right"
                   Margin="0,12,0,0">
            <Button x:Name="CloseButton"
                    MinWidth="110"
                    MaxWidth="160"
                    Click="CloseButton_Click"
                    Content="Schließen"/>
        </WrapPanel>
    </Grid>
</Window>