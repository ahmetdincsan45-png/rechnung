<Window x:Class="Örnek.ArtikelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Leistungskatalog / Artikelstamm" Height="650" Width="1050" MinHeight="540" MinWidth="760" WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <WrapPanel Grid.Row="0" Margin="0,0,0,10">
            <Button x:Name="NewButton" MinWidth="110" MaxWidth="180" Margin="0,0,10,10" Click="Yeni_Click" Content="Neu"/>
            <Button x:Name="DeleteButton" MinWidth="110" MaxWidth="180" Margin="0,0,10,10" Click="Sil_Click" Content="Löschen"/>
            <Button x:Name="SaveButton" MinWidth="110" MaxWidth="180" Margin="0,0,10,10" Click="Kaydet_Click" Content="Speichern"/>
        </WrapPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.8*"/>
                <ColumnDefinition Width="1.2*"/>
            </Grid.ColumnDefinitions>

            <DataGrid x:Name="ArtikelGrid" Grid.Column="0" AutoGenerateColumns="False" IsReadOnly="True"
                      SelectionChanged="ArtikelGrid_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn x:Name="ArtikelNrColumn" Header="Nr." Binding="{Binding ArtikelNr}" Width="110"/>
                    <DataGridTextColumn x:Name="ArtikelNameColumn" Header="Bezeichnung" Binding="{Binding Bezeichnung}" Width="*"/>
                    <DataGridTextColumn x:Name="ArtikelUnitColumn" Header="Einheit" Binding="{Binding Einheit}" Width="90"/>
                    <DataGridTextColumn x:Name="ArtikelPriceColumn" Header="Preis" Binding="{Binding StandardPreis, StringFormat=N2}" Width="110"/>
                    <DataGridTextColumn x:Name="ArtikelTaxColumn" Header="MwSt.%" Binding="{Binding StandardMwSt, StringFormat=0.##}" Width="80"/>
                    <DataGridCheckBoxColumn x:Name="ArtikelActiveColumn" Header="Aktiv" Binding="{Binding Aktiv}" Width="70"/>
                </DataGrid.Columns>
            </DataGrid>

            <GroupBox x:Name="DetailGroupBox" Grid.Column="1" Header="Details" Margin="18,0,0,0" MinWidth="280">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="ArtikelNrLabel" Grid.Row="0" Grid.Column="0" Margin="0,0,10,8" VerticalAlignment="Center" TextWrapping="Wrap" Text="Nr.:"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" Text="{Binding Selected.ArtikelNr, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock x:Name="ArtikelNameLabel" Grid.Row="1" Grid.Column="0" Margin="0,0,10,8" VerticalAlignment="Center" TextWrapping="Wrap" Text="Bezeichnung:"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" Text="{Binding Selected.Bezeichnung, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock x:Name="ArtikelUnitLabel" Grid.Row="2" Grid.Column="0" Margin="0,0,10,8" VerticalAlignment="Center" TextWrapping="Wrap" Text="Einheit:"/>
                        <ComboBox Grid.Row="2" Grid.Column="1" Margin="0,0,0,8"
                                  IsEditable="True"
                                  ItemsSource="{StaticResource Einheiten}"
                                  Text="{Binding Selected.Einheit, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock x:Name="ArtikelPriceLabel" Grid.Row="3" Grid.Column="0" Margin="0,0,10,8" VerticalAlignment="Center" TextWrapping="Wrap" Text="Preis:"/>
                        <TextBox Grid.Row="3" Grid.Column="1" Margin="0,0,0,8" Text="{Binding Selected.StandardPreis, Converter={StaticResource FlexibleDecimalConverter}, ConverterParameter=N2, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock x:Name="ArtikelTaxLabel" Grid.Row="4" Grid.Column="0" Margin="0,0,10,8" VerticalAlignment="Center" TextWrapping="Wrap" Text="MwSt.%:"/>
                        <TextBox Grid.Row="4" Grid.Column="1" Margin="0,0,0,8" Text="{Binding Selected.StandardMwSt, Converter={StaticResource FlexibleDecimalConverter}, ConverterParameter=0.##, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock x:Name="ArtikelDescriptionLabel" Grid.Row="5" Grid.Column="0" Margin="0,0,10,0" VerticalAlignment="Top" TextWrapping="Wrap" Text="Beschreibung:"/>
                        <TextBox Grid.Row="5" Grid.Column="1" Height="120" TextWrapping="Wrap" AcceptsReturn="True"
                                 Text="{Binding Selected.Beschreibung, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                </ScrollViewer>
            </GroupBox>
        </Grid>

        <WrapPanel Grid.Row="2" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="CloseButton" MinWidth="110" MaxWidth="180" Margin="0,0,10,0" Click="Kapat_Click" Content="Schließen"/>
        </WrapPanel>
    </Grid>
</Window>
