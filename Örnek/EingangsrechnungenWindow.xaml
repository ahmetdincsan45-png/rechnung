<Window x:Class="Örnek.EingangsrechnungenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:conv="clr-namespace:Örnek.Converters"
        mc:Ignorable="d"
         Title="Eingangsrechnungen" Height="720" Width="1220" MinWidth="840" MinHeight="520" WindowStartupLocation="CenterOwner"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        RenderOptions.ClearTypeHint="Enabled">
    <Window.Resources>
        <conv:FlexibleDecimalConverter x:Key="FlexibleDecimalConverter"/>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <WrapPanel Grid.Row="0" Margin="0,0,0,12" ItemHeight="34">
            <Button x:Name="ImportButton" MinWidth="130" MaxWidth="180" Margin="0,0,10,10" Click="Import_Click" Content="Datei importieren"/>
            <Button x:Name="ScanButton" MinWidth="110" MaxWidth="160" Margin="0,0,10,10" Click="Scan_Click" Content="Scannen"/>
            <Button x:Name="AnalyzeButton" MinWidth="130" MaxWidth="180" Margin="0,0,10,10" Click="Analyze_Click" Content="OCR analysieren"/>
            <Button x:Name="OpenOcrFolderButton" MinWidth="150" MaxWidth="210" Margin="0,0,10,10" Click="OpenOcrFolder_Click" Content="OCR-Ordner öffnen"/>
            <Button x:Name="SaveButton" MinWidth="110" MaxWidth="160" Margin="0,0,10,10" Click="Save_Click" Content="Speichern"/>
            <Button x:Name="DeleteButton" MinWidth="110" MaxWidth="160" Margin="0,0,10,10" Click="Delete_Click" Content="Löschen"/>
            <Button x:Name="OpenButton" MinWidth="130" MaxWidth="180" Margin="0,0,10,10" Click="Open_Click" Content="Dokument öffnen"/>
            <Button x:Name="OpenFolderButton" MinWidth="130" MaxWidth="180" Margin="0,0,10,10" Click="OpenFolder_Click" Content="Ordner öffnen"/>
            <Button x:Name="RefreshButton" MinWidth="110" MaxWidth="160" Margin="0,0,0,10" Click="Refresh_Click" Content="Aktualisieren"/>
        </WrapPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.95*"/>
                <ColumnDefinition Width="1.55*"/>
            </Grid.ColumnDefinitions>

            <GroupBox x:Name="ListGroupBox" Header="Archivierte Eingangsrechnungen" Margin="0,0,14,0">
                <DataGrid x:Name="InvoicesGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          SelectionChanged="InvoicesGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn x:Name="SupplierColumn" Header="Lieferant" Binding="{Binding Lieferant}" Width="*"/>
                        <DataGridTextColumn x:Name="InvoiceNumberColumn" Header="Rechnungsnr." Binding="{Binding Rechnungsnummer}" Width="150"/>
                        <DataGridTextColumn x:Name="InvoiceDateColumn" Header="Datum" Binding="{Binding Rechnungsdatum, StringFormat=dd.MM.yyyy}" Width="120"/>
                        <DataGridTextColumn x:Name="GrossColumn" Header="Brutto" Binding="{Binding Brutto, StringFormat=N2}" Width="110"/>
                        <DataGridTextColumn x:Name="ProjectColumn" Header="Projekt" Binding="{Binding Projekt}" Width="160"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <GroupBox x:Name="DetailsGroupBox" Grid.Column="1" Header="Belegdetails">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="128"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="SupplierLabel" Grid.Row="0" Grid.Column="0" Margin="0,0,10,8" VerticalAlignment="Center" Text="Lieferant:"/>
                        <TextBox x:Name="SupplierTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" Text="{Binding Selected.Lieferant, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock x:Name="InvoiceNumberLabel" Grid.Row="1" Grid.Column="0" Margin="0,0,10,8" VerticalAlignment="Center" Text="Rechnungsnr.:"/>
                        <TextBox x:Name="InvoiceNumberTextBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" Text="{Binding Selected.Rechnungsnummer, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock x:Name="InvoiceDateLabel" Grid.Row="2" Grid.Column="0" Margin="0,0,10,8" VerticalAlignment="Center" Text="Rechnungsdatum:"/>
                        <DatePicker x:Name="InvoiceDatePicker" Grid.Row="2" Grid.Column="1" Margin="0,0,0,8" SelectedDate="{Binding Selected.Rechnungsdatum, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock x:Name="NetLabel" Grid.Row="3" Grid.Column="0" Margin="0,0,10,8" VerticalAlignment="Center" Text="Netto:"/>
                        <TextBox x:Name="NetTextBox" Grid.Row="3" Grid.Column="1" Margin="0,0,0,8" Text="{Binding Selected.Netto, Converter={StaticResource FlexibleDecimalConverter}, ConverterParameter=N2, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock x:Name="TaxLabel" Grid.Row="4" Grid.Column="0" Margin="0,0,10,8" VerticalAlignment="Center" Text="MwSt.:"/>
                        <TextBox x:Name="TaxTextBox" Grid.Row="4" Grid.Column="1" Margin="0,0,0,8" Text="{Binding Selected.MwSt, Converter={StaticResource FlexibleDecimalConverter}, ConverterParameter=N2, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock x:Name="GrossLabel" Grid.Row="5" Grid.Column="0" Margin="0,0,10,8" VerticalAlignment="Center" Text="Brutto:"/>
                        <TextBox x:Name="GrossTextBox" Grid.Row="5" Grid.Column="1" Margin="0,0,0,8" Text="{Binding Selected.Brutto, Converter={StaticResource FlexibleDecimalConverter}, ConverterParameter=N2, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock x:Name="ProjectLabel" Grid.Row="6" Grid.Column="0" Margin="0,0,10,8" VerticalAlignment="Center" Text="Projekt / Objekt:"/>
                        <TextBox x:Name="ProjectTextBox" Grid.Row="6" Grid.Column="1" Margin="0,0,0,8" Text="{Binding Selected.Projekt, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock x:Name="CategoryLabel" Grid.Row="7" Grid.Column="0" Margin="0,0,10,8" VerticalAlignment="Center" Text="Kategorie:"/>
                        <TextBox x:Name="CategoryTextBox" Grid.Row="7" Grid.Column="1" Margin="0,0,0,8" Text="{Binding Selected.Kategorie, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock x:Name="ArchivedInvoiceSelectLabel" Grid.Row="8" Grid.Column="0" Margin="0,0,10,8" VerticalAlignment="Center" Text="Archivierte Rechnung:"/>
                        <ComboBox x:Name="ArchivedInvoiceComboBox"
                                  Grid.Row="8"
                                  Grid.Column="1"
                                  Margin="0,0,0,8"
                                  DisplayMemberPath="DisplayText"
                                  SelectionChanged="ArchivedInvoiceComboBox_SelectionChanged"/>

                        <TextBlock x:Name="AssignedInvoiceLabel" Grid.Row="9" Grid.Column="0" Margin="0,0,10,8" VerticalAlignment="Center" Text="Zugeordnete Rechnung:"/>
                        <TextBox x:Name="AssignedInvoiceTextBox" Grid.Row="9" Grid.Column="1" Margin="0,0,0,8" Text="{Binding Selected.ZugeordneteRechnungNummer, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock x:Name="SuggestedInvoiceLabel" Grid.Row="10" Grid.Column="0" Margin="0,0,10,8" VerticalAlignment="Center" Text="Vorschlag:"/>
                        <ComboBox x:Name="SuggestedInvoiceComboBox"
                                  Grid.Row="10"
                                  Grid.Column="1"
                                  Margin="0,0,0,8"
                                  DisplayMemberPath="DisplayText"
                                  SelectionChanged="SuggestedInvoiceComboBox_SelectionChanged"/>

                        <TextBlock x:Name="DetectedSupplierLabel" Grid.Row="11" Grid.Column="0" Margin="0,0,10,8" VerticalAlignment="Center" Text="Erkannter Lieferant:"/>
                        <TextBlock x:Name="DetectedSupplierValueText" Grid.Row="11" Grid.Column="1" Margin="0,0,0,8" Text="{Binding Selected.ErkannterLieferant}" TextWrapping="Wrap"/>

                        <TextBlock x:Name="DetectedInvoiceNumberLabel" Grid.Row="12" Grid.Column="0" Margin="0,0,10,8" VerticalAlignment="Center" Text="Erkannte Rechnungsnr.:"/>
                        <TextBlock x:Name="DetectedInvoiceNumberValueText" Grid.Row="12" Grid.Column="1" Margin="0,0,0,8" Text="{Binding Selected.ErkannteRechnungsnummer}" TextWrapping="Wrap"/>

                        <TextBlock x:Name="DetectedOcrTextLabel" Grid.Row="13" Grid.Column="0" Margin="0,0,10,8" VerticalAlignment="Top" Text="OCR-Text:"/>
                        <StackPanel Grid.Row="13" Grid.Column="1">
                            <TextBlock x:Name="OcrStatusTextBlock" Margin="0,0,0,6" Foreground="{StaticResource AppTextSecondaryBrush}" Text="OCR bereit" TextWrapping="Wrap"/>
                            <TextBox x:Name="DetectedOcrTextBox" Height="110" Margin="0,0,0,8" IsReadOnly="True" Text="{Binding Selected.OcrText}" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                        </StackPanel>

                        <TextBlock x:Name="OriginalFileLabel" Grid.Row="14" Grid.Column="0" Margin="0,0,10,8" VerticalAlignment="Center" Text="Originaldatei:"/>
                        <TextBlock x:Name="OriginalFileValueText" Grid.Row="14" Grid.Column="1" Margin="0,0,0,8" Text="{Binding Selected.OriginalDateiname}" TextWrapping="Wrap"/>

                        <TextBlock x:Name="NoteLabel" Grid.Row="15" Grid.Column="0" Margin="0,0,10,0" VerticalAlignment="Top" Text="Notiz:"/>
                        <TextBox x:Name="NoteTextBox" Grid.Row="15" Grid.Column="1" Height="180" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                 Text="{Binding Selected.Notiz, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                </ScrollViewer>
            </GroupBox>
        </Grid>
    </Grid>
</Window>
