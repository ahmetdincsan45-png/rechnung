<Window x:Class="Örnek.EmailSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="E-Mail-Einstellungen" Height="520" Width="520" MinHeight="420" MinWidth="420" WindowStartupLocation="CenterOwner">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,10,8" VerticalAlignment="Center" TextWrapping="Wrap" Text="SMTP Host:"/>
            <TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" Text="{Binding Settings.SmtpHost, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,10,8" VerticalAlignment="Center" TextWrapping="Wrap" Text="Port:"/>
            <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" Text="{Binding Settings.SmtpPort, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,10,8" VerticalAlignment="Center" TextWrapping="Wrap" Text="SSL:"/>
            <CheckBox x:Name="SslCheckBox" Grid.Row="2" Grid.Column="1" Margin="0,0,0,8" IsChecked="{Binding Settings.EnableSsl}" Content="SSL aktivieren"/>

            <TextBlock x:Name="UserLabel" Grid.Row="3" Grid.Column="0" Margin="0,0,10,8" VerticalAlignment="Center" TextWrapping="Wrap" Text="Benutzer:"/>
            <TextBox Grid.Row="3" Grid.Column="1" Margin="0,0,0,8" Text="{Binding Settings.Username, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock x:Name="PasswordLabel" Grid.Row="4" Grid.Column="0" Margin="0,0,10,8" VerticalAlignment="Center" TextWrapping="Wrap" Text="Passwort:"/>
            <PasswordBox Grid.Row="4" Grid.Column="1" Margin="0,0,0,8" x:Name="PasswordBox"/>

            <TextBlock x:Name="FromAddressLabel" Grid.Row="5" Grid.Column="0" Margin="0,0,10,8" VerticalAlignment="Center" TextWrapping="Wrap" Text="Absender-E-Mail:"/>
            <TextBox Grid.Row="5" Grid.Column="1" Margin="0,0,0,8" Text="{Binding Settings.FromAddress, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock x:Name="FromNameLabel" Grid.Row="6" Grid.Column="0" Margin="0,0,10,8" VerticalAlignment="Center" TextWrapping="Wrap" Text="Absendername:"/>
            <TextBox Grid.Row="6" Grid.Column="1" Margin="0,0,0,8" Text="{Binding Settings.FromName, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock x:Name="NoteLabel" Grid.Row="7" Grid.Column="0" Margin="0,0,10,0" VerticalAlignment="Center" TextWrapping="Wrap" Text="Hinweis:"/>
            <TextBlock x:Name="NoteText" Grid.Row="7" Grid.Column="1" TextWrapping="Wrap" Foreground="#666"
                       Text="Das Passwort wird als JSON unter AppData gespeichert. Sie können das Feld leer lassen."/>
        </Grid>
        </ScrollViewer>

        <WrapPanel Grid.Row="1" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="CancelButton" MinWidth="110" MaxWidth="180" Margin="0,0,10,10" Click="Cancel_Click" Content="Abbrechen"/>
            <Button x:Name="SaveButton" MinWidth="110" MaxWidth="180" Margin="0,0,0,10" Click="Save_Click" Content="Speichern"/>
        </WrapPanel>
    </Grid>
</Window>
